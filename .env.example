# --- Supabase (cliente: SOMENTE anon key; service_role NUNCA vai ao bundle) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Server-side (Edge Functions) ---
SUPABASE_SERVICE_ROLE_KEY=server-only-never-in-frontend

# --- Observabilidade ---
VITE_SENTRY_DSN=

# --- IA (adapter default: Anthropic) ---
ANTHROPIC_API_KEY=server-only
AI_PROVIDER=anthropic   # anthropic | openai | local

# --- Pagamentos (Stripe primário; Mercado Pago futuro) ---
STRIPE_SECRET_KEY=server-only
STRIPE_WEBHOOK_SECRET=server-only
PAYMENT_PROVIDER=stripe # stripe | mercadopago
